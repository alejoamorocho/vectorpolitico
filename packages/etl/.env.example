# ──────────────────────────────────────────────────────────────
# Brújula Política — ETL environment variables (EJEMPLO)
# ──────────────────────────────────────────────────────────────
#
# Copia este archivo a `.env` y rellena los valores reales.
# `.env` está en .gitignore — NUNCA lo commitees.
#
# Si filtras una key por accidente, rótala inmediatamente:
#   - Anthropic: https://console.anthropic.com/settings/keys
#   - Wayback:   https://archive.org/account/s3.php
# ──────────────────────────────────────────────────────────────

# OBLIGATORIO para classify_entity.py
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# OPCIONAL — solo si usas archivado automático via S3-compatible de IA
WAYBACK_API_KEY=

# User-Agent respetuoso para GDELT y scraping
USER_AGENT=brujula-politica/0.1 (+https://github.com/ssi-co/vectorpolitico)

# Rutas relativas al directorio etl/
DATA_DIR=./data
OUTPUT_DIR=./data/classified
