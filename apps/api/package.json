{
  "name": "@brujula/api",
  "version": "0.1.0",
  "private": true,
  "description": "API Cloudflare Worker + Hono para Brújula Política",
  "license": "Apache-2.0",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts'",
    "test": "vitest run",
    "migrate:local": "wrangler d1 migrations apply brujula-politica --local",
    "migrate:staging": "wrangler d1 migrations apply brujula-politica-staging --remote",
    "migrate:prod": "wrangler d1 migrations apply brujula-politica --remote"
  },
  "dependencies": {
    "@brujula/schema": "workspace:*",
    "@hono/zod-validator": "^0.4.1",
    "hono": "^4.6.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "@cloudflare/workers-types": "^4.20240925.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5",
    "wrangler": "^3.78.0"
  }
}
