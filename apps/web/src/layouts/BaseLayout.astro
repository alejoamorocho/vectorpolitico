---
import '@/styles/globals.css';
import BrandMark from '@/components/BrandMark';

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
}

const {
  title,
  description = 'Gaceta política de Colombia — propuestas contra la realidad, con fuentes primarias.',
  image = '/og-default.png',
  canonicalURL = Astro.url.toString(),
} = Astro.props;

const fullTitle = title === 'La Brújula' ? title : `${title} · La Brújula`;

// Fecha en español para el dateline tipo periódico
const now = new Date();
const weekdays = ['Domingo', 'Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado'];
const months = [
  'Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio',
  'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre',
];
const dateline = `${weekdays[now.getDay()]}, ${now.getDate()} de ${months[now.getMonth()]} de ${now.getFullYear()}`;
---

<!doctype html>
<html lang="es-CO">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url).toString()} />
    <meta property="og:url" content={canonicalURL} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <meta name="theme-color" content="#f5efe2" />
    <meta name="color-scheme" content="light" />

    <!-- Tipografía gazette -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,600&family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- ═══════════════════ MASTHEAD ═══════════════════ -->
    <header>
      <div class="masthead">
        <div class="mx-auto max-w-[1400px] px-6">
          <p class="masthead-meta">Vol. I · Núm. 1 · Edición de Colombia · Apache 2.0</p>
          <h1 class="masthead-title">La Brújula</h1>
          <p style="font-style: italic; font-family: var(--font-serif); letter-spacing: 0.02em; font-size: 13px; margin-top: 6px; color: var(--ink-mute);">
            Gaceta política · propuestas contra la realidad
          </p>
          <div class="masthead-dateline">
            <span>Bogotá — {dateline}</span>
            <span>«Non de dicere, sed de facere»</span>
            <span>Open source · v0.1</span>
          </div>
        </div>
      </div>

      <nav class="newsnav sticky top-0 z-20">
        <div class="newsnav-inner">
          <a href="/" class="newsnav-link">Portada</a>
          <a href="/figuras" class="newsnav-link">Figuras</a>
          <a href="/partidos" class="newsnav-link">Partidos</a>
          <a href="/ideologias" class="newsnav-link">Ideologías</a>
          <a href="/metodologia" class="newsnav-link">Metodología</a>
          <a href="/about" class="newsnav-link">Acerca</a>
          <a href="/contribuir" class="newsnav-link">Contribuir</a>
        </div>
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <!-- ═══════════════════ FOOTER ═══════════════════ -->
    <footer class="mt-24" style="background: var(--paper-raised); border-top: 3px double var(--ink);">
      <div class="mx-auto max-w-[1400px] px-6 py-14">
        <div class="grid md:grid-cols-[1.5fr_1fr_1fr_1fr] gap-10">
          <div>
            <BrandMark client:load />
            <p class="mt-4 text-sm max-w-sm leading-relaxed" style="font-family: var(--font-serif); color: var(--ink-mute); font-style: italic;">
              Gaceta política de código abierto dedicada a ubicar a figuras y partidos
              colombianos en el espectro ideológico — basada en hechos verificables, no en opiniones.
            </p>
          </div>
          <div>
            <p style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-mute); margin-bottom: 12px;">
              Explorar
            </p>
            <ul class="space-y-2 text-sm" style="font-family: var(--font-serif); font-style: italic;">
              <li><a href="/figuras" style="color: var(--ink-soft); text-decoration: none;">Figuras</a></li>
              <li><a href="/partidos" style="color: var(--ink-soft); text-decoration: none;">Partidos</a></li>
              <li><a href="/ideologias" style="color: var(--ink-soft); text-decoration: none;">Ideologías</a></li>
            </ul>
          </div>
          <div>
            <p style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-mute); margin-bottom: 12px;">
              Metodología
            </p>
            <ul class="space-y-2 text-sm" style="font-family: var(--font-serif); font-style: italic;">
              <li><a href="/metodologia/compass-scoring" style="color: var(--ink-soft); text-decoration: none;">Scoring</a></li>
              <li><a href="/metodologia/incoherence-standard" style="color: var(--ink-soft); text-decoration: none;">Estándar</a></li>
              <li><a href="/metodologia/data-sources" style="color: var(--ink-soft); text-decoration: none;">Fuentes</a></li>
            </ul>
          </div>
          <div>
            <p style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-mute); margin-bottom: 12px;">
              Proyecto
            </p>
            <ul class="space-y-2 text-sm" style="font-family: var(--font-serif); font-style: italic;">
              <li><a href="/about" style="color: var(--ink-soft); text-decoration: none;">Acerca de</a></li>
              <li><a href="/contribuir" style="color: var(--ink-soft); text-decoration: none;">Contribuir</a></li>
              <li><a href="https://github.com/alejoamorocho/vectorpolitico" style="color: var(--ink-soft); text-decoration: none;">GitHub</a></li>
            </ul>
          </div>
        </div>
        <div class="mt-12 pt-6 flex flex-wrap gap-4 justify-between items-center text-xs" style="border-top: 1px solid var(--rule); color: var(--ink-mute); font-family: var(--font-serif); font-style: italic;">
          <p>Iniciativa de <a href="https://github.com/alejoamorocho" style="color: var(--ink-mute); text-decoration: underline;">Alejo Amorocho</a>, Cali, Colombia.</p>
          <p style="font-family: var(--font-mono); font-style: normal;">v0.1.0 · datos provisionales</p>
        </div>
      </div>
    </footer>
  </body>
</html>
