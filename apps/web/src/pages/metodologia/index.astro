---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const docs = (await getCollection('methodology', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order,
);

const bySection = docs.reduce<Record<string, typeof docs>>((acc, d) => {
  (acc[d.data.section] ??= []).push(d);
  return acc;
}, {});

const sectionLabels = {
  compass: { title: 'El compass', desc: 'Cómo se calcula el posicionamiento ideológico' },
  incoherence: { title: 'Incoherencias', desc: 'Estándar para documentar contradicciones' },
  data: { title: 'Fuentes', desc: 'De dónde vienen los datos' },
  contributing: { title: 'Contribuir', desc: 'Cómo aportar al proyecto' },
  adr: { title: 'Decisiones técnicas', desc: 'Architectural Decision Records' },
} as const;

const sectionOrder = ['compass', 'incoherence', 'data', 'contributing', 'adr'] as const;
const ornaments = ['❦', '§', '◊', '¶', '✦'];
---

<BaseLayout title="Metodología" description="La metodología pública, auditable y versionada de La Brújula.">
  <div class="page-header">
    <div class="page-header-inner">
      <p class="section-kicker">Wiki</p>
      <h1 style="margin-top: 0.5rem;">Metodología</h1>
      <p class="page-lead">
        <em>Pública, versionada y auditable</em>. Toda posición en el mapa debe justificarse con
        hechos verificables y fuentes primarias. Aquí explicamos exactamente cómo.
      </p>
    </div>
  </div>

  <section class="mx-auto max-w-[900px] px-6 pb-20">
    {sectionOrder.map((section, idx) => {
      const list = bySection[section];
      if (!list?.length) return null;
      const meta = sectionLabels[section];
      return (
        <section class="mb-16">
          {idx > 0 && (
            <div class="rule-ornament">
              <span class="rule-ornament-glyph">{ornaments[idx % ornaments.length]}</span>
            </div>
          )}
          <div class="mb-6 pb-4" style="border-bottom: 2px solid var(--ink);">
            <p class="section-kicker">Capítulo {String(idx + 1).padStart(2, '0')}</p>
            <h2 style="margin-top: 4px;">{meta.title}</h2>
            <p class="section-byline mt-2"><em>{meta.desc}</em></p>
          </div>
          <ul style="list-style: none; padding: 0;">
            {list.map((doc, i) => (
              <li>
                <a
                  href={`/metodologia/${doc.slug}`}
                  class="grid grid-cols-[auto_1fr] gap-5 py-5"
                  style="text-decoration: none; color: var(--ink); border-bottom: 1px solid var(--rule);"
                >
                  <span style="font-family: var(--font-display); font-size: 32px; font-weight: 700; color: var(--ink-faint); line-height: 1;">
                    {String(i + 1).padStart(2, '0')}
                  </span>
                  <div>
                    <p style="font-family: var(--font-display); font-size: 24px; font-weight: 600; line-height: 1.2; margin: 0;">
                      {doc.data.title}
                    </p>
                    <p class="section-byline section-byline--sm mt-1" style="max-width: 60ch;">
                      <em>{doc.data.description}</em>
                    </p>
                    <p class="section-kicker mt-2">
                      v{doc.data.version} · {doc.data.lastUpdated.toLocaleDateString('es-CO')}
                    </p>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </section>
      );
    })}
  </section>
</BaseLayout>
