{
  "name": "@brujula/web",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Frontend de Brújula Política (Astro 5 + React + D3)",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "astro dev",
    "dev:node": "astro dev --config ./astro.config.dev.mjs",
    "start": "astro dev",
    "build": "astro build && pagefind --site dist",
    "build:node": "astro build --config ./astro.config.dev.mjs && pagefind --site dist",
    "preview": "astro preview",
    "preview:node": "astro preview --config ./astro.config.dev.mjs",
    "serve:dist": "node ./scripts/serve-dist.mjs",
    "astro": "astro",
    "typecheck": "astro check && tsc --noEmit",
    "lint": "eslint 'src/**/*.{ts,tsx,astro}'",
    "test": "vitest run"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/cloudflare": "^12.0.0",
    "@astrojs/react": "^4.0.0",
    "@astrojs/tailwind": "^5.1.2",
    "@brujula/data": "workspace:*",
    "@brujula/schema": "workspace:*",
    "@phosphor-icons/react": "^2.1.7",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.3",
    "astro": "^5.0.0",
    "astro-pagefind": "^1.7.0",
    "d3-quadtree": "^3.0.1",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "framer-motion": "^12.40.0",
    "nanostores": "^0.11.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.13",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@astrojs/node": "^9.5.5",
    "@types/d3-quadtree": "^3.0.6",
    "@types/d3-scale": "^4.0.8",
    "@types/d3-selection": "^3.0.10",
    "@types/d3-zoom": "^3.0.8",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "pagefind": "^1.1.1",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
