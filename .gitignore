# ──────────────────────────────────────────────────────────────────────
# Brújula Política — .gitignore
# Defensa primaria contra filtración de secrets.
# NO MODIFICAR sin consultar docs/contributing/SECURITY.md
# ──────────────────────────────────────────────────────────────────────

# Node / pnpm
node_modules/
dist/
build/
.astro/
.wrangler/
.cache/
.turbo/
.vercel/
.output/
*.tsbuildinfo

# Pnpm specific
.pnpm-store/
.pnpm-debug.log*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
ENV/
.python-version
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# ──────────── SECRETS — nunca commitear ────────────
.env
.env.*
!.env.example
.dev.vars
!.dev.vars.example
*.local
secrets/
*.pem
*.key
*.p12
*.pfx
.anthropic/
.cloudflare/

# Cloudflare local state (contiene D1 local con datos potencialmente sensibles)
.wrangler/

# IDE / editores
.vscode/*
!.vscode/settings.json.example
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Testing / coverage
coverage/
*.lcov

# OS
.DS_Store
Desktop.ini

# Data crudo (ETL puede generar mucho)
packages/etl/data/raw/**
!packages/etl/data/raw/.gitkeep
packages/etl/data/news/**
!packages/etl/data/news/.gitkeep

# Temporary
tmp/
temp/
*.tmp

# Artefactos intermedios de enriquecimiento (no versionar)
scripts/enrich/in/
scripts/enrich/out/
scripts/enrich/*-ids.json
scripts/enrich/*-slugs.json
scripts/enrich/*-manifest.json

# Artefactos locales (no portables)
.claude/launch.json
scripts/enrich/audit-findings.json
